# Optional. Without these values the app uses mock generation so the workflow stays usable.
# This machine usually exports OAI_KEY from zsh. OPENAI_API_KEY also works.
OAI_KEY=
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2

# Optional unified Ark Agent Plan path. This is an opt-in fallback that leaves the existing key
# layout intact. With REELYAI_USE_AGENT_PLAN=1, Seedance / Seedream / VLM Ark calls use the Agent
# Plan key and the dedicated /plan base URL. Without the flag, existing service-specific keys win;
# if those keys are absent, ARK_AGENT_PLAN_KEY is tried automatically.
# Official docs: https://www.volcengine.com/docs/82379/2373738?lang=zh
ARK_AGENT_PLAN_KEY=
ARK_AGENT_PLAN_BASE=https://ark.cn-beijing.volces.com/api/plan/v3
REELYAI_USE_AGENT_PLAN=
SEEDREAM_AGENT_PLAN_MODEL=doubao-seedream-5.0-lite
# Optional text model for Agent Plan prompt expansion / rewrite. Leave empty to use the local
# template expander instead of calling an unsupported standard text model through /api/plan/v3.
SEED_PROMPT_AGENT_PLAN_MODEL=
PROMPT_REWRITE_AGENT_PLAN_MODEL=
AGENT_PLAN_TEXT_MODEL=
SEEDANCE_AGENT_PLAN_MODEL=doubao-seedance-2-0-260128
SEEDANCE_AGENT_PLAN_FAST_MODEL=doubao-seedance-2-0-fast-260128

# Default Seedream image generation backend for asset references.
# Seedream 4.5 is the default model in the UI. If SEEDREAM_API_KEY is empty, BP_ARK_API_KEY and
# ARK_API_KEY are also tried. ARK_AGENT_PLAN_KEY is tried after those keys, or first when
# REELYAI_USE_AGENT_PLAN=1.
SEEDREAM_API_KEY=
SEEDREAM_API_BASE=https://ark.ap-southeast.bytepluses.com/api/v3
SEEDREAM_MODEL=seedream-4-0-250828
SEEDREAM_45_MODEL=seedream-4-5-251128
SEEDREAM_SIZE=4K
# Seedream image calls enable web_search by default. Set to 0/false/no/off to disable.
SEEDREAM_WEB_SEARCH=

# Optional public base for locally stored storyboard/reference images.
# Must be reachable by remote Seedance workers; do not use localhost.
# Example: https://your-public-tunnel.example.com
PUBLIC_MEDIA_BASE_URL=

# Optional: publish imported Codex storyboards to Volcengine TOS so remote Seedance can fetch them.
# Follow the TOS quickstart to create/access a bucket. TOS_ENDPOINT is optional when the SDK can
# derive it from region, but setting it explicitly is recommended. ARK_AGENT_PLAN_KEY does not
# replace TOS AK/SK; if you skip TOS, use a non-local PUBLIC_MEDIA_BASE_URL for local references.
TOS_ACCESS_KEY_ID=
TOS_SECRET_ACCESS_KEY=
# Also accepted: TOS_ACCESS_KEY / TOS_SECRET_KEY, matching the Volcengine SDK examples.
TOS_REGION=cn-beijing
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_BUCKET=
# If the bucket/CDN is public, set this to the public object root, for example:
# https://your-bucket.tos-cn-beijing.volces.com
# If empty, the app stores a pre-signed URL instead.
TOS_PUBLIC_BASE_URL=
TOS_KEY_PREFIX=cinema-agent/storyboards
TOS_PRESIGN_EXPIRES_SEC=604800

# Seedance. By default the app uses BytePlus Ark async content-generation.
# Prefer BP_ARK_API_KEY when available. SEEDANCE_API_URL is only for a custom direct endpoint.
# ARK_AGENT_PLAN_KEY is tried after the existing keys, or first when REELYAI_USE_AGENT_PLAN=1.
BP_ARK_API_KEY=
SEEDANCE_API_BASE=https://ark.ap-southeast.bytepluses.com/api/v3
SEEDANCE_MODEL=dreamina-seedance-2-0-260128
SEEDANCE_FAST_MODEL=dreamina-seedance-2-0-fast-260128
SEEDANCE_RATIO=16:9
SEEDANCE_RESOLUTION=
SEEDANCE_GENERATE_AUDIO=true
SEEDANCE_WATERMARK=false
SEEDANCE_POLL_MS=5000
SEEDANCE_TIMEOUT_MS=900000

# Optional custom direct endpoint override.
SEEDANCE_API_KEY=
SEEDANCE_API_URL=

# Volcengine OpenSpeech v3 single-shot SSE TTS for the auto narration + subtitle feature.
# Doc: https://www.volcengine.com/docs/6561/1598757
# Without VOLC_TTS_APPID + VOLC_TTS_TOKEN the narration pipeline returns a readable error in the UI
# and does NOT fall back to other TTS providers. ARK_AGENT_PLAN_KEY does not replace these
# OpenSpeech credentials.
# Tip: if you prefer setting these in ~/.zshrc, remember to use `export VOLC_TTS_APPID=...`
# (a bare `VOLC_TTS_APPID="..."` assignment is local to the shell and will NOT be inherited by
# `npm run dev`'s child node process). Setting them in this .env file is the most foolproof.
# VOLC_TTS_RESOURCE_ID picks the model family:
#   - seed-tts-1.0   (default) — most appids only have 1.0 authorized; works for the *_bigtts
#                    speakers we ship by default (zh_male_M392_conversation_wvae_bigtts etc.) and
#                    for the en_* English voices.
#   - seed-tts-2.0   only switch to this if your appid console explicitly opens 2.0 access; on a
#                    1.0-only appid every TTS call returns 55000000 "resource ID mismatch".
VOLC_TTS_APPID=
VOLC_TTS_TOKEN=
VOLC_TTS_RESOURCE_ID=seed-tts-1.0
VOLC_TTS_VOICE_TYPE=zh_male_M392_conversation_wvae_bigtts
VOLC_TTS_BASE=https://openspeech.bytedance.com/api/v3/tts/unidirectional/sse
VOLC_TTS_RATE=24000
# Hard cap of the global atempo applied to the narration track so it fits inside the video.
# Final video length is NEVER extended: if the narration is still too long after capping at this
# tempo, the trailing sentences are truncated (and a warning is surfaced in the UI/log).
NARRATION_FIT_MAX_TEMPO=1.30
# Default gap inserted between adjacent narration sentences, in milliseconds.
NARRATION_GAP_MS=200
# Original ambient track is attenuated by this many dB before mixing with narration so the spoken
# line stays intelligible while the soundscape remains audible. -12 dB ~= volume=0.25.
NARRATION_AMBIENT_DB=-12
# Subtitle rendering. ffmpeg-installer ships an ffmpeg built with libass but WITHOUT libfontconfig,
# so libass cannot resolve system-wide font names like "PingFang SC" — they fall back to Helvetica
# which has no CJK glyphs, rendering as ⬛⬛⬛. Workaround: point libass at a directory that contains
# a single .ttf with full CJK + Latin coverage, and reference it by its PostScript name.
# macOS default below works out of the box and covers Chinese + English + punctuation.
NARRATION_SUBTITLE_FONT=Arial Unicode MS
NARRATION_SUBTITLE_FONTSDIR=/System/Library/Fonts/Supplemental
