{
  "name": "reelyai-agent",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server/index.ts",
    "build": "tsc --noEmit && vite build && node scripts/inline-entry-assets.mjs",
    "verify": "npm run verify:offline",
    "verify:offline": "npm run smoke:lock-registry && npm run build && npm run smoke:canvas-crud && npm run smoke:asset-prompt && npm run smoke:vlm-review-toggle && tsx scripts/smoke-fetch-retry.ts && tsx scripts/smoke_narration_units.mjs",
    "verify:release": "npm run verify:offline && npm run smoke:guardrails",
    "verify:integration": "npm run test:ark-credentials",
    "test:ark-credentials": "tsx scripts/test-ark-credentials.ts",
    "verify:canvas-crud": "npm run build && npm run smoke:canvas-crud",
    "smoke:asset-prompt": "tsx scripts/smoke-asset-prompt.ts",
    "smoke:canvas-crud": "tsx scripts/smoke-canvas-crud.ts",
    "smoke:lock-registry": "tsx scripts/smoke-lock-registry.ts",
    "smoke:vlm-review-toggle": "tsx scripts/smoke-vlm-review-toggle.ts",
    "smoke:guardrails": "tsx scripts/smoke-guardrails.ts",
    "smoke:production": "tsx scripts/smoke-production.ts",
    "cli": "node packages/reelyai-cli/bin/reelyai.js",
    "cli:pack": "npm pack ./packages/reelyai-cli",
    "install:skill": "node scripts/install_agent_skill.mjs",
    "postinstall": "node scripts/install_agent_skill.mjs --postinstall || true",
    "start": "NODE_ENV=production tsx src/server/index.ts"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@volcengine/tos-sdk": "^2.9.1",
    "@xyflow/react": "^12.10.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "pg": "^8.21.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vite": "^7.1.7"
  },
  "devDependencies": {
    "@rollup/wasm-node": "^4.60.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
