    "verify:canvas-crud": "npm run build && npm run smoke:canvas-crud",
    "smoke:asset-prompt": "tsx scripts/smoke-asset-prompt.ts",
    "smoke:seedance-language-lock": "tsx scripts/smoke-seedance-language-lock.ts",
    "smoke:seedance-cast-filter": "tsx scripts/smoke-seedance-cast-filter.ts",
    "smoke:canvas-crud": "tsx scripts/smoke-canvas-crud.ts",
    "smoke:canvas-node-layout": "tsx scripts/smoke-canvas-node-layout.ts",
