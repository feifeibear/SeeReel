{
  "name": "seereel-agent",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server/index.ts",
    "build": "tsc --noEmit && vite build && node scripts/inline-entry-assets.mjs",
    "verify": "npm run verify:offline",
    "verify:offline": "npm run smoke:lock-registry && npm run smoke:specs && npm run smoke:client-routes && npm run smoke:seereel-cli && npm run smoke:secrets && npm run build && npm run smoke:canvas-crud && npm run smoke:gallery-sharing && npm run smoke:tailframe-preview-url && npm run smoke:tailframe-strict && npm run smoke:asset-prompt && npm run smoke:vlm-review-toggle && tsx scripts/smoke-fetch-retry.ts && tsx scripts/smoke_narration_units.mjs",
    "verify:release": "npm run verify:offline && npm run smoke:guardrails",
    "verify:integration": "npm run test:ark-credentials",
    "test:ark-credentials": "tsx scripts/test-ark-credentials.ts",
    "verify:canvas-crud": "npm run build && npm run smoke:canvas-crud",
    "smoke:asset-prompt": "tsx scripts/smoke-asset-prompt.ts",
    "smoke:canvas-crud": "tsx scripts/smoke-canvas-crud.ts",
    "smoke:lock-registry": "tsx scripts/smoke-lock-registry.ts",
    "smoke:seereel-cli": "node scripts/smoke-seereel-cli.mjs",
    "smoke:seereel-cli-status": "node scripts/smoke-seereel-cli-status.mjs",
    "smoke:seereel-cli-cloud-only": "node scripts/smoke-seereel-cli-cloud-only.mjs",
    "smoke:seereel-director-skill": "node scripts/smoke-seereel-director-skill.mjs",
    "smoke:seereel-handoff": "node scripts/smoke-seereel-handoff.mjs",
    "smoke:secrets": "tsx scripts/smoke-secrets.ts",
    "smoke:specs": "tsx scripts/smoke-specs.ts",
    "smoke:client-routes": "tsx scripts/smoke-client-routes.ts",
    "smoke:vlm-review-toggle": "tsx scripts/smoke-vlm-review-toggle.ts",
    "smoke:guardrails": "tsx scripts/smoke-guardrails.ts",
    "smoke:gallery-sharing": "tsx scripts/smoke-gallery-sharing.ts",
    "smoke:tailframe-preview-url": "tsx scripts/smoke-tailframe-preview-url.ts",
    "smoke:tailframe-strict": "tsx scripts/smoke-tailframe-strict.ts",
    "smoke:production": "tsx scripts/smoke-production.ts",
    "cli": "node packages/seereel-cli/bin/seereelcli.js",
    "cli:pack": "npm pack ./packages/seereel-cli",
    "install:skill": "node scripts/install_agent_skill.mjs",
    "postinstall": "node -e \"if(process.env.CI||process.env.SEEREEL_SKIP_SKILL_INSTALL==='1'||process.env.REELYAI_SKIP_SKILL_INSTALL==='1'){console.log('Skipping SeeReel skill installation during postinstall.');process.exit(0)}process.exit(1)\" || node scripts/install_agent_skill.mjs --postinstall || true",
    "start": "NODE_ENV=production tsx src/server/index.ts"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@volcengine/tos-sdk": "^2.9.1",
    "@xyflow/react": "^12.10.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "pg": "^8.21.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vite": "^7.1.7"
  },
  "devDependencies": {
    "@rollup/wasm-node": "^4.60.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
