{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "title": "ReelyAI 产品运营",
  "uid": "reelyai-product-ops",
  "tags": ["reelyai", "ops"],
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "row",
      "title": "访问数据",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100
    },
    {
      "type": "stat",
      "title": "今日访客",
      "id": 1,
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "reelyai-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "expr": "reelyai_visitors_unique_today", "instant": true, "range": false, "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "24h 访客",
      "id": 2,
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "reelyai-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "expr": "reelyai_visitors_unique_24h", "instant": true, "range": false, "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "24h 页面访问",
      "id": 3,
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "reelyai-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "steps": [{ "color": "purple", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "expr": "sum(increase(reelyai_page_views_total[24h])) or vector(0)", "instant": true, "range": false, "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "服务状态",
      "id": 4,
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "reelyai-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "expr": "up{job=\"reelyai\"}", "instant": true, "range": false, "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "访问趋势",
      "id": 5,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "reelyai-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } },
      "targets": [{ "expr": "sum(increase(reelyai_page_views_total[5m])) or vector(0)", "legendFormat": "page views / 5m", "refId": "A" }]
    },
    {
      "type": "row",
      "title": "模型调用",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 101
    },
    {
      "type": "stat",
      "title": "24h Seedance 2.0 调用",
      "id": 6,
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "reelyai-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "steps": [{ "color": "orange", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "expr": "sum(increase(reelyai_model_calls_total{model_family=~\"seedance-2-0.*\"}[24h])) or vector(0)", "instant": true, "range": false, "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "24h Seedream 调用",
      "id": 7,
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "reelyai-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "expr": "sum(increase(reelyai_model_calls_total{model_family=~\"seedream-.*\"}[24h])) or vector(0)", "instant": true, "range": false, "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "当前生成产物",
      "id": 8,
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "reelyai-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "expr": "sum(reelyai_model_artifacts_total{model_family=~\"seedance-2-0.*|seedream-.*\"}) or vector(0)", "instant": true, "range": false, "refId": "A" }]
    },
    {
      "type": "barchart",
      "title": "生成产物累计（按模型族）",
      "id": 9,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "reelyai-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } },
      "targets": [{ "expr": "sum by (model_family) (reelyai_model_artifacts_total{model_family=~\"seedance-2-0.*|seedream-.*\"})", "instant": true, "range": false, "legendFormat": "{{model_family}}", "refId": "A" }]
    },
    {
      "type": "table",
      "title": "调用次数与 Token 事件（按 provider/model/operation）",
      "id": 10,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "reelyai-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } },
      "targets": [
        { "expr": "reelyai_token_usage_events_total", "instant": true, "range": false, "legendFormat": "{{provider}} / {{model}} / {{operation}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "模型调用趋势",
      "id": 11,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "reelyai-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } },
      "targets": [
        { "expr": "sum by (model_family) (increase(reelyai_model_calls_total{model_family=~\"seedance-2-0.*|seedream-.*\"}[5m]))", "legendFormat": "{{model_family}} / 5m", "refId": "A" }
      ]
    }
  ]
}
