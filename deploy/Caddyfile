(seereel_backend) {
	encode zstd gzip
	log {
		output stdout
		format json
	}

	@private path /metrics /api/diagnostics
	handle @private {
		respond "not found" 404
	}

	reverse_proxy seereel:5173
}

{$CADDY_SITE_ADDRESS} {
	{$CADDY_TLS_DIRECTIVE}
	import seereel_backend
}

{$CADDY_HTTP_SITE_ADDRESS::80} {
	import seereel_backend
}
