NODE_ENV=production
PORT=5173
SEEREEL_COOKIE_SECURE=1

# --- Release guardrails (STRONGLY recommended on a public deployment) ---
# Shared access token gate. When set, sensitive routes (all writes, /api/state, /api/diagnostics)
# require an `x-seereel-access` header. Generate a strong random value, e.g. `openssl rand -hex 24`.
# Leaving this empty exposes every paid generation API to anyone who can reach the server.
SEEREEL_ACCESS_TOKEN=
# Per-session hard cap on paid generation submissions per UTC day (0 disables the cap).
SEEREEL_SESSION_GENERATION_DAILY_CAP=1000

# Volcengine PostgreSQL storage for browser-entered Agent Plan keys. The Docker Compose deploy
# runs a private Postgres container on ECS by default. For external Volcengine RDS, replace
# SEEREEL_DATABASE_URL with the RDS connection string. Keep the encryption secret stable; changing
# it makes existing DB rows unreadable.
SEEREEL_DATABASE_URL=postgres://seereel:change-me@postgres:5432/seereel
SEEREEL_DATABASE_SSL=
SEEREEL_AGENT_PLAN_KEY_ENCRYPTION_SECRET=
POSTGRES_DB=seereel
POSTGRES_USER=seereel
POSTGRES_PASSWORD=
SEEREEL_NODE_IMAGE=docker.m.daocloud.io/library/node:22-bookworm-slim
SEEREEL_CADDY_IMAGE=docker.m.daocloud.io/library/caddy:2-alpine
SEEREEL_POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:16-alpine

# Public origin of this deployment, for share links and public media fallback.
# Example: https://seereel.example.com or https://203.0.113.10.sslip.io
APP_PUBLIC_URL=
CADDY_SITE_ADDRESS=
ACME_EMAIL=

# --- Observability (used by deploy/docker-compose.observability.yml) ---
# Grafana admin password (change from the default).
GRAFANA_ADMIN_PASSWORD=
# Feishu custom-bot webhook for alert delivery (Alertmanager -> feishu-alert-relay -> Feishu).
FEISHU_WEBHOOK_URL=
# Optional Feishu webhook signing secret (enable "签名校验" on the bot, then set it here).
FEISHU_WEBHOOK_SECRET=

# Do NOT put your own ARK_AGENT_PLAN_KEY here for a public deployment.
# Visitors enter their own Agent Plan token in the SeeReel top bar; it is kept server-side only.
ARK_AGENT_PLAN_BASE=https://ark.cn-beijing.volces.com/api/plan/v3
SEEDREAM_AGENT_PLAN_MODEL=doubao-seedream-5.0-lite
SEEDANCE_AGENT_PLAN_MODEL=doubao-seedance-2-0-260128
SEEDANCE_AGENT_PLAN_FAST_MODEL=doubao-seedance-2-0-fast-260128
SEED_PROMPT_AGENT_PLAN_MODEL=
PROMPT_REWRITE_AGENT_PLAN_MODEL=
AGENT_PLAN_TEXT_MODEL=
SEEREEL_VISION_REVIEW_USE_AGENT_PLAN=
VISION_REVIEW_AGENT_PLAN_MODEL=doubao-seed-2.0-pro
VIDEO_ANALYZE_AGENT_PLAN_MODEL=doubao-seed-2.0-pro

# Optional standard Ark VLM review / reference-video analysis. Leave empty on public deployments
# unless the server operator wants to pay for review from a backend key.
VISION_REVIEW_API_KEY=
VISION_REVIEW_API_BASE=https://ark.ap-southeast.bytepluses.com/api/v3
VISION_REVIEW_MODEL=seed-2-0-pro-260328
VIDEO_ANALYZE_MODEL=

# Backend-only TOS storage. Prefer a private bucket; SeeReel will generate signed URLs for workers.
TOS_ACCESS_KEY_ID=
TOS_SECRET_ACCESS_KEY=
TOS_REGION=cn-beijing
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_BUCKET=
TOS_KEY_PREFIX=cinema-agent/storyboards
TOS_PRESIGN_EXPIRES_SEC=604800
TOS_PUBLIC_BASE_URL=

SEEDANCE_RATIO=16:9
SEEDANCE_GENERATE_AUDIO=true
SEEDANCE_WATERMARK=false
SEEDANCE_POLL_MS=5000
SEEDANCE_TIMEOUT_MS=900000

# Optional narration.
VOLC_TTS_APPID=
VOLC_TTS_TOKEN=
VOLC_TTS_RESOURCE_ID=seed-tts-1.0
VOLC_TTS_VOICE_TYPE=zh_male_M392_conversation_wvae_bigtts
VOLC_TTS_BASE=https://openspeech.bytedance.com/api/v3/tts/unidirectional/sse
VOLC_TTS_RATE=24000
